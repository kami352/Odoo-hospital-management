<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Sequence -->
    <record id="seq_appointment" model="ir.sequence">
        <field name="name">Appointment Sequence</field>
        <field name="code">hospital.appointment</field>
        <field name="prefix">APP/</field>
        <field name="padding">3</field>
        <field name="number_increment">1</field>
    </record>

    <!-- List view -->
    <record id="view_appointment_list" model="ir.ui.view">
        <field name="name">hospital.appointment.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="reference"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="department_id"/>
                <field name="date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form view – cleaned & correct -->
    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
               <header>
    <field name="state" widget="statusbar" clickable="1"/>
    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
    <button name="action_done" string="Mark as Done" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
    <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" invisible="state in ['cancel', 'done']"/>
    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancel'"/>
    <button name="%(hospital_management.report_prescription)d" string="Print Prescription" type="action" class="oe_highlight" icon="fa-print" invisible="state not in ['confirmed', 'done']"/>
    
   <button name="%(hospital_management.action_cancel_appointment_wizard)d" 
        string="Cancel" 
        type="action" 
        class="oe_highlight" 
        invisible="state in ['cancel', 'done']" 
        context="{'default_appointment_id': id}"/>

   

    
</header>
                <sheet>
                    <group>
                        <field name="reference" readonly="1"/>
                        <field name="patient_id" readonly="state in ['done', 'cancel']"/>
                        <field name="doctor_id" readonly="state in ['done', 'cancel']"/>
                        <field name="department_id" readonly="1"/>
                        <field name="date" readonly="state in ['done', 'cancel']"/>
                        <field name="state" invisible="1"/>
                        <field name="notes" readonly="state in ['done', 'cancel']"/>
                        <field name="prescription" readonly="state in ['done', 'cancel']"/>
                        <field name="treatment_notes" readonly="state in ['done', 'cancel']"/>
                    </group>

                    <!-- Cancellation info – only visible on cancel -->
                    
                </sheet>
            </form>
        </field>
    </record>

    <!-- Calendar View for Appointments -->
<record id="view_appointment_calendar" model="ir.ui.view">
    <field name="name">hospital.appointment.calendar</field>
    <field name="model">hospital.appointment</field>
    <field name="arch" type="xml">
        <calendar date_start="date" 
                  color="state" 
                  mode="month" 
                  event_open_popup="1" 
                  create="true" 
                  delete="true">
            <field name="reference"/>
            <field name="patient_id"/>
            <field name="doctor_id"/>
            <field name="department_id"/>
            <field name="state"/>
        </calendar>
    </field>
</record>


    <!-- Action -->
  <record id="action_appointment" model="ir.actions.act_window">
    <field name="name">Appointments</field>
    <field name="res_model">hospital.appointment</field>
    
    <!-- Order: list first, then calendar, then form -->
    <field name="view_mode">list,calendar,form</field>

    <!-- Explicit view order – no comments inside eval -->
    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('hospital_management.view_appointment_list')}),
        (0, 0, {'view_mode': 'calendar', 'view_id': ref('hospital_management.view_appointment_calendar')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('hospital_management.view_appointment_form')})]"/>
</record>

</odoo>