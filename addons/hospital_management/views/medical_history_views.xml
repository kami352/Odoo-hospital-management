<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View for Medical History -->
    <record id="view_medical_history_list" model="ir.ui.view">
        <field name="name">hospital.medical.history.list</field>
        <field name="model">hospital.medical.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="diagnosis"/>
                <field name="treatment"/>
                <field name="allergy" widget="boolean_toggle"/>
                <field name="allergy_description" optional="hide"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View for Medical History -->
 <record id="view_medical_history_form" model="ir.ui.view">
    <field name="name">hospital.medical.history.form</field>
    <field name="model">hospital.medical.history</field>
    <field name="arch" type="xml">
        <form string="Medical History Entry">
            <sheet>
                <group>
                    <group>
                        <field name="patient_id" readonly="1"/>
                        <field name="date"/>
                        <field name="doctor_id"/>
                        <field name="diagnosis"/>
                    </group>
                    <group>
                        <field name="treatment"/>
                        <field name="allergy"/>
                        <!-- Conditional invisible – Odoo 18 syntax -->
                        <field name="allergy_description" invisible="not allergy"/>
                    </group>
                </group>
                <group>
                    <field name="notes"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

    <!-- Action to open Medical History (standalone) -->
    <record id="action_medical_history" model="ir.actions.act_window">
        <field name="name">Medical History</field>
        <field name="res_model">hospital.medical.history</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('patient_id', '!=', False)]</field>
    </record>

    <!-- Menu item under Hospital (optional) -->
    <menuitem 
        id="menu_medical_history" 
        name="Medical History" 
        parent="menu_hospital_root" 
        action="hospital_management.action_medical_history" 
        sequence="6"/>

</odoo>