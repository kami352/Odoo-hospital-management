<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View – FIXED -->
    <record id="view_patient_list" model="ir.ui.view">
        <field name="name">hospital.patient.list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="image_small" widget="image" options='{"size": [64, 64]}'/>
                <field name="phone"/>
                <field name="email"/>
                <field name="age"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <!-- Form View – looks good, no change needed -->
    <record id="view_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <!-- Smart button box -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_appointments" type="object" class="oe_stat_button" icon="fa-calendar">
                            <field name="appointment_count" widget="statinfo" string="Appointments"/>
                        </button>
                    </div>

                    <!-- Two-column layout with photo on left -->
                    <group col="3">
                        <group colspan="1">
                            <field name="image" widget="image" class="oe_avatar" options='{"preview_image": "image_small", "size": [256, 256]}'/>
                        </group>

                        <group colspan="2">
                            <group string="Personal Information">
                                <field name="name"/>
                                <field name="age"/>
                                <field name="gender"/>
                                <field name="phone"/>
                                <field name="mobile"/>
                                <field name="email"/>
                            </group>

                            <group string="Address">
                                <field name="street"/>
                                <field name="street2"/>
                                <field name="city"/>
                                <field name="zip"/>
                                <field name="country_id"/>
                            </group>
                        </group>
                    </group>

                    <!-- Notebook / Appointments tab -->
                    <notebook>
                        <page string="Appointments">
                            <field name="appointment_ids">
                                <list editable="bottom">
                                    <field name="reference"/>
                                    <field name="doctor_id"/>
                                    <field name="date"/>
                                    <field name="state" widget="badge"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="reference"/>
                                        <field name="doctor_id"/>
                                        <field name="date"/>
                                        <field name="state"/>
                                        <field name="notes"/>
                                    </group>
                                </form>
                            </field>
                        </page>


                        <page string="Medical History">
        <field name="medical_history_ids">
            <list editable="bottom">
                <field name="date"/>
                <field name="doctor_id"/>
                <field name="diagnosis"/>
                <field name="treatment"/>
                <field name="allergy" widget="boolean_toggle"/>
                <field name="allergy_description" optional="hide"/>
                <field name="notes" optional="hide"/>
            </list>
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="doctor_id"/>
                            <field name="diagnosis"/>
                        </group>
                        <group>
                            <field name="treatment"/>
                            <field name="allergy"/>
                            <field name="allergy_description" attrs="{'invisible': [('allergy', '=', False)]}"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>