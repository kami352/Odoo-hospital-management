<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Report Action -->
    <record id="report_prescription" model="ir.actions.report">
        <field name="name">Prescription</field>
        <field name="model">hospital.appointment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_management.prescription_template</field>
        <field name="report_file">hospital_management.prescription</field>
        <field name="binding_model_id" ref="hospital_management.model_hospital_appointment"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <!-- Simple Prescription Template -->
    <template id="prescription_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">Prescription</h2>
                        <hr/>

                        <div class="row mt-3">
                            <div class="col-6">
                                <strong>Patient:</strong> <span t-field="o.patient_id.name"/>
                            </div>
                            <div class="col-6 text-right">
                                <strong>Date:</strong> <span t-field="o.date" t-options='{"format": "dd/MM/yyyy HH:mm"}'/>
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-6">
                                <strong>Doctor:</strong> <span t-field="o.doctor_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Department:</strong> <span t-field="o.department_id.name"/>
                            </div>
                        </div>

                        <hr class="mt-4 mb-4"/>

                        <h3>Prescription</h3>
                        <div t-field="o.prescription" style="min-height: 150px; white-space: pre-wrap;"/>

                        <h3>Additional Notes</h3>
                        <div t-field="o.notes" style="min-height: 100px; white-space: pre-wrap;"/>

                        <div class="mt-5 text-center">
                            <p><strong>Doctor Signature:</strong> ___________________________</p>
                            <p><strong>Date:</strong> <span t-field="o.date" t-options='{"format": "dd/MM/yyyy"}'/></p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>